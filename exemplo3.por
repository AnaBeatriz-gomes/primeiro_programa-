
programa {
    funcao inicio() {
        real desempenho
        
        escreva("Digite o seu desempenho no curso: ")
        leia(desempenho)
        
        se (desempenho >= 7) {
            escreva("Uall! Muito bem!")
        } senao {
            escreva("Poxa. Se esforçe mais!")
        }
    }
}
            